/* === KALI'S KINGDOM — Sweet Apricot Kawaii === */

:root {
  --apricot: #ffb88c;
  --peach: #ffd4b8;
  --blush: #ffe4e1;
  --cream: #fff9f5;
  --cloud: #ffffff;
  --lavender: #e8daf8;
  --mint: #c8f4ef;
  --butter: #fff3c4;
  --baby-blue: #d4e7ff;
  --rose: #ffc4d6;
  --ink: #4a3728;
  --ink-light: #8b7355;
  --ink-faint: #c4a882;
  --radius-big: 32px;
  --radius-card: 24px;
  --radius-pill: 999px;
  --radius-door: 28px;
  --shadow-soft: 0 8px 32px rgba(74, 55, 40, 0.08);
  --shadow-lift: 0 12px 40px rgba(74, 55, 40, 0.12);
  --shadow-glow: 0 4px 20px rgba(255, 184, 140, 0.3);
  --font-display: 'Baloo 2', 'Fredoka', system-ui, sans-serif;
  --font-body: 'Nunito', system-ui, sans-serif;
  --font-handwritten: 'Caveat', cursive;
}

*, *::before, *::after { box-sizing: border-box; }

html {
  -webkit-tap-highlight-color: transparent;
  -webkit-text-size-adjust: 100%;
}

html, body, #root {
  margin: 0;
  min-height: 100dvh;
}

body {
  font-family: var(--font-body);
  color: var(--ink);
  background: var(--cream);
  overscroll-behavior: none;
}

/* === APP SHELL === */
.kingdom {
  width: min(100%, 820px);
  margin: 0 auto;
  min-height: 100dvh;
  padding: 20px 20px 140px;
  position: relative;
  overflow-x: hidden;
}

/* Floating clouds background */
.kingdom::before {
  content: '';
  position: fixed;
  inset: 0;
  background:
    radial-gradient(ellipse 600px 200px at 10% 20%, rgba(255, 212, 184, 0.3), transparent),
    radial-gradient(ellipse 400px 300px at 85% 60%, rgba(232, 218, 248, 0.25), transparent),
    radial-gradient(ellipse 500px 200px at 50% 90%, rgba(200, 244, 239, 0.2), transparent),
    linear-gradient(180deg, var(--cream) 0%, #fff5f0 50%, var(--cream) 100%);
  pointer-events: none;
  z-index: -1;
}

/* === CARDS === */
.kk-card {
  background: var(--cloud);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-soft);
  padding: 20px;
  margin-bottom: 16px;
  border: 2px solid rgba(255, 184, 140, 0.15);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.kk-card:active {
  transform: scale(0.98);
}

/* === TYPOGRAPHY === */
.kk-title {
  font-family: var(--font-display);
  font-weight: 700;
  line-height: 1.1;
  margin: 0 0 6px;
  color: var(--ink);
}

.kk-subtitle {
  font-family: var(--font-body);
  font-weight: 600;
  color: var(--ink-light);
  margin: 0;
  font-size: 0.92rem;
}

.kk-handwritten {
  font-family: var(--font-handwritten);
  font-weight: 600;
}

/* === PILLS === */
.kk-pill {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  border-radius: var(--radius-pill);
  padding: 6px 14px;
  font-family: var(--font-body);
  font-weight: 800;
  font-size: 0.78rem;
  letter-spacing: 0.02em;
  text-transform: uppercase;
}

.kk-pill--apricot { background: var(--peach); color: #7a4a1a; }
.kk-pill--mint { background: var(--mint); color: #1a6b5a; }
.kk-pill--lavender { background: var(--lavender); color: #5a3d7a; }
.kk-pill--rose { background: var(--rose); color: #7a2a4a; }
.kk-pill--butter { background: var(--butter); color: #6b5a1a; }

/* === BUTTONS === */
.kk-btn {
  border: none;
  border-radius: var(--radius-pill);
  padding: 14px 24px;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 0.95rem;
  cursor: pointer;
  transition: all 0.2s ease;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
  position: relative;
  overflow: hidden;
}

.kk-btn:active {
  transform: scale(0.95);
}

.kk-btn--primary {
  background: linear-gradient(135deg, var(--apricot), #ffa070);
  color: white;
  box-shadow: var(--shadow-glow);
}

.kk-btn--primary:active {
  box-shadow: 0 2px 10px rgba(255, 184, 140, 0.4);
}

.kk-btn--secondary {
  background: var(--cloud);
  color: var(--ink);
  border: 2px solid rgba(255, 184, 140, 0.3);
}

.kk-btn--mood {
  background: var(--cloud);
  color: var(--ink);
  border: 2px solid transparent;
  padding: 12px 16px;
  font-size: 0.88rem;
  box-shadow: 0 4px 16px rgba(74, 55, 40, 0.06);
}

.kk-btn--mood.active {
  border-color: var(--apricot);
  background: linear-gradient(135deg, rgba(255, 184, 140, 0.15), rgba(255, 212, 184, 0.2));
  box-shadow: var(--shadow-glow);
  transform: scale(1.02);
}

.kk-btn--small {
  padding: 8px 16px;
  font-size: 0.82rem;
}

/* === HEADER === */
.kk-header {
  text-align: center;
  padding: 8px 0 4px;
  margin-bottom: 8px;
}

.kk-header__crown {
  font-size: 2rem;
  line-height: 1;
  margin-bottom: 2px;
}

.kk-header__title {
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 800;
  background: linear-gradient(135deg, var(--apricot), #e88a60, var(--lavender));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin: 0;
  line-height: 1.1;
}

.kk-header__sub {
  font-family: var(--font-handwritten);
  font-size: 1.15rem;
  color: var(--ink-light);
  margin: 4px 0 0;
}

/* === TWIX HERO === */
.kk-hero {
  border-radius: var(--radius-big);
  padding: 0;
  overflow: hidden;
  position: relative;
  transition: background 0.5s ease;
}

.kk-hero__inner {
  display: grid;
  grid-template-columns: 140px 1fr;
  gap: 0;
  align-items: center;
}

.kk-hero__img-wrap {
  padding: 16px 8px 16px 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.kk-hero__img {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  object-fit: cover;
  border: 4px solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 8px 24px rgba(74, 55, 40, 0.15);
  transition: transform 0.4s ease, opacity 0.3s ease;
}

.kk-hero__img.entering {
  animation: twixBounce 0.5s ease;
}

@keyframes twixBounce {
  0% { transform: scale(0.8) rotate(-5deg); opacity: 0.5; }
  50% { transform: scale(1.08) rotate(3deg); }
  100% { transform: scale(1) rotate(0deg); opacity: 1; }
}

.kk-hero__text {
  padding: 20px 20px 20px 8px;
}

.kk-hero__says {
  font-family: var(--font-handwritten);
  font-size: 0.95rem;
  color: var(--ink-faint);
  margin: 0 0 4px;
}

.kk-hero__line {
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 700;
  margin: 0 0 6px;
  line-height: 1.2;
}

.kk-hero__subtitle {
  font-size: 0.82rem;
  color: var(--ink-light);
  margin: 0 0 12px;
  line-height: 1.4;
  font-style: italic;
}

/* === MOOD PICKER === */
.kk-moods {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding: 4px 0 8px;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.kk-moods::-webkit-scrollbar { display: none; }

.kk-moods__label {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 700;
  margin: 0 0 8px;
}

/* === QUEST DOORS (Invitation Cards) === */
.kk-doors__title {
  font-family: var(--font-display);
  font-size: 1.2rem;
  font-weight: 700;
  margin: 0 0 4px;
}

.kk-doors__subtitle {
  font-size: 0.82rem;
  color: var(--ink-light);
  margin: 0 0 12px;
}

.kk-door {
  border-radius: var(--radius-door);
  padding: 16px;
  margin-bottom: 12px;
  background: var(--cloud);
  border: 2px solid rgba(255, 184, 140, 0.12);
  box-shadow: 0 6px 24px rgba(74, 55, 40, 0.06);
  cursor: pointer;
  transition: all 0.25s ease;
  -webkit-tap-highlight-color: transparent;
  position: relative;
  overflow: hidden;
}

.kk-door::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  border-radius: var(--radius-door) var(--radius-door) 0 0;
  transition: background 0.3s ease;
}

.kk-door:active {
  transform: scale(0.98);
  box-shadow: 0 2px 12px rgba(74, 55, 40, 0.08);
}

.kk-door__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8px;
}

.kk-door__mess {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  display: inline-block;
  flex-shrink: 0;
  margin-top: 6px;
}

.kk-door__name {
  font-family: var(--font-display);
  font-size: 1.08rem;
  font-weight: 700;
  margin: 4px 0;
  flex: 1;
}

.kk-door__story {
  font-size: 0.88rem;
  color: var(--ink-light);
  margin: 0;
  line-height: 1.45;
}

.kk-door__role {
  font-family: var(--font-handwritten);
  font-size: 0.95rem;
  color: var(--ink-faint);
  margin: 6px 0 0;
}

/* === EXPANDED QUEST CARD === */
.kk-quest-overlay {
  position: fixed;
  inset: 0;
  background: rgba(74, 55, 40, 0.4);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 100;
  display: grid;
  place-items: center;
  padding: 20px;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.kk-quest {
  background: var(--cloud);
  border-radius: var(--radius-big);
  max-width: 600px;
  width: 100%;
  max-height: 85dvh;
  overflow-y: auto;
  padding: 28px 24px;
  box-shadow: 0 24px 80px rgba(74, 55, 40, 0.2);
  animation: slideUp 0.3s ease;
  position: relative;
}

@keyframes slideUp {
  from { transform: translateY(40px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.kk-quest__close {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: none;
  background: var(--blush);
  font-size: 1.2rem;
  cursor: pointer;
  display: grid;
  place-items: center;
  transition: all 0.2s;
  color: var(--ink-light);
}

.kk-quest__close:active { transform: scale(0.9); }

.kk-quest__world {
  font-family: var(--font-handwritten);
  font-size: 0.95rem;
  color: var(--ink-faint);
  margin: 0 0 4px;
}

.kk-quest__title {
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 800;
  margin: 0 0 12px;
  padding-right: 40px;
}

.kk-quest__story-box {
  border-radius: 20px;
  padding: 16px;
  margin: 0 0 16px;
}

.kk-quest__story-label {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 0.88rem;
  margin: 0 0 6px;
}

.kk-quest__story-text {
  font-size: 0.9rem;
  line-height: 1.5;
  margin: 0 0 8px;
}

.kk-quest__tiers {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin: 0 0 16px;
}

.kk-quest__tier {
  border-radius: 20px;
  padding: 14px 12px;
  text-align: center;
  border: 2px solid transparent;
  cursor: pointer;
  transition: all 0.2s;
  background: var(--cream);
}

.kk-quest__tier:active { transform: scale(0.95); }

.kk-quest__tier.selected {
  border-color: var(--apricot);
  background: rgba(255, 184, 140, 0.1);
}

.kk-quest__tier-label {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 0.78rem;
  margin: 0 0 4px;
}

.kk-quest__tier-desc {
  font-size: 0.8rem;
  color: var(--ink-light);
  margin: 0;
  line-height: 1.3;
}

.kk-quest__protip {
  border-radius: 16px;
  padding: 14px;
  margin: 0 0 16px;
  background: var(--butter);
  border: 2px solid rgba(255, 243, 196, 0.5);
}

.kk-quest__protip-label {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 0.82rem;
  margin: 0 0 4px;
}

.kk-quest__protip-text {
  font-size: 0.85rem;
  line-height: 1.45;
  margin: 0;
  color: var(--ink-light);
}

.kk-quest__twix {
  font-family: var(--font-handwritten);
  font-size: 1.1rem;
  color: var(--ink-faint);
  text-align: center;
  margin: 12px 0;
  font-style: italic;
}

.kk-quest__actions {
  display: flex;
  gap: 10px;
  margin-top: 16px;
}

.kk-quest__actions .kk-btn { flex: 1; text-align: center; }

/* === ASK MOMMY STATE === */
.kk-ask-mommy {
  text-align: center;
  padding: 32px 20px;
}

.kk-ask-mommy__emoji {
  font-size: 3rem;
  margin-bottom: 12px;
  animation: gentleBounce 2s infinite ease-in-out;
}

@keyframes gentleBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

.kk-ask-mommy__title {
  font-family: var(--font-display);
  font-size: 1.3rem;
  font-weight: 700;
  margin: 0 0 8px;
}

.kk-ask-mommy__text {
  font-size: 0.92rem;
  color: var(--ink-light);
  margin: 0 0 16px;
  line-height: 1.5;
}

.kk-ask-mommy__suggestions {
  text-align: left;
  margin-top: 16px;
}

.kk-ask-mommy__suggestions h4 {
  font-family: var(--font-display);
  font-size: 0.95rem;
  margin: 0 0 8px;
  color: var(--ink-faint);
}

.kk-ask-mommy__suggestion {
  padding: 10px 14px;
  border-radius: 16px;
  background: var(--cream);
  margin-bottom: 8px;
  font-size: 0.88rem;
  cursor: pointer;
  transition: all 0.2s;
  border: 2px solid transparent;
}

.kk-ask-mommy__suggestion:active {
  transform: scale(0.98);
  border-color: var(--apricot);
}

/* === GALLERY === */
.kk-gallery-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  border-radius: 16px;
  background: var(--cream);
  margin-bottom: 8px;
}

.kk-gallery-item__badge {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  font-size: 1.3rem;
  flex-shrink: 0;
}

.kk-gallery-item__info { flex: 1; min-width: 0; }

.kk-gallery-item__name {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 0.92rem;
  margin: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.kk-gallery-item__caption {
  font-size: 0.78rem;
  color: var(--ink-light);
  margin: 2px 0 0;
  font-style: italic;
}

.kk-gallery-item__date {
  font-size: 0.72rem;
  color: var(--ink-faint);
  margin: 0;
}

/* === DRAW A QUEST BUTTON === */
.kk-draw-quest {
  position: relative;
  overflow: hidden;
}

.kk-draw-quest .sparkle {
  position: absolute;
  pointer-events: none;
  animation: sparkleFloat 0.6s ease forwards;
}

@keyframes sparkleFloat {
  0% { transform: scale(0) translateY(0); opacity: 1; }
  50% { transform: scale(1.2) translateY(-20px); opacity: 0.8; }
  100% { transform: scale(0.5) translateY(-40px); opacity: 0; }
}

/* === COMPLETION CELEBRATION === */
.kk-celebrate {
  position: fixed;
  inset: 0;
  z-index: 200;
  display: grid;
  place-items: center;
  background: rgba(255, 249, 245, 0.95);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  animation: fadeIn 0.3s ease;
}

.kk-celebrate__inner {
  text-align: center;
  padding: 40px;
  animation: celebratePop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes celebratePop {
  0% { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.kk-celebrate__stamp {
  font-size: 4rem;
  margin-bottom: 16px;
}

.kk-celebrate__title {
  font-family: var(--font-display);
  font-size: 1.8rem;
  font-weight: 800;
  margin: 0 0 8px;
}

.kk-celebrate__badge {
  display: inline-block;
  padding: 8px 20px;
  border-radius: var(--radius-pill);
  background: linear-gradient(135deg, var(--apricot), var(--rose));
  color: white;
  font-family: var(--font-display);
  font-weight: 700;
  margin: 12px 0;
}

.kk-celebrate__caption {
  font-family: var(--font-handwritten);
  font-size: 1.1rem;
  color: var(--ink-light);
  margin: 8px 0 20px;
}

/* === SOFT NAV === */
.kk-nav {
  position: fixed;
  bottom: 12px;
  left: 50%;
  transform: translateX(-50%);
  width: min(calc(100% - 32px), 500px);
  display: flex;
  justify-content: space-around;
  gap: 4px;
  padding: 10px 8px;
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow: 0 8px 40px rgba(74, 55, 40, 0.12);
  z-index: 50;
}

.kk-nav__item {
  border: none;
  background: transparent;
  padding: 8px 12px;
  border-radius: 16px;
  font-family: var(--font-body);
  font-weight: 700;
  font-size: 0.75rem;
  color: var(--ink-light);
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.kk-nav__item.active {
  color: var(--ink);
  background: rgba(255, 184, 140, 0.15);
}

.kk-nav__icon {
  font-size: 1.2rem;
}

/* === MOMMY MODE === */
.kk-mommy {
  animation: slideUp 0.3s ease;
}

.kk-mommy__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}

.kk-mommy__tabs {
  display: flex;
  gap: 6px;
  overflow-x: auto;
  padding: 4px 0 8px;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.kk-mommy__tabs::-webkit-scrollbar { display: none; }

.kk-mommy__tab {
  border: none;
  background: var(--cloud);
  border-radius: var(--radius-pill);
  padding: 10px 16px;
  font-family: var(--font-body);
  font-weight: 700;
  font-size: 0.82rem;
  color: var(--ink-light);
  cursor: pointer;
  white-space: nowrap;
  transition: all 0.2s;
  border: 2px solid transparent;
}

.kk-mommy__tab.active {
  background: var(--peach);
  color: var(--ink);
  border-color: var(--apricot);
}

/* Mommy mode activity picker */
.kk-mommy-picker {
  display: grid;
  gap: 8px;
}

.kk-mommy-picker__item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  border-radius: 16px;
  border: 2px solid rgba(255, 184, 140, 0.12);
  background: var(--cloud);
  cursor: pointer;
  transition: all 0.2s;
}

.kk-mommy-picker__item:active {
  transform: scale(0.98);
}

.kk-mommy-picker__item.selected {
  border-color: var(--apricot);
  background: rgba(255, 184, 140, 0.08);
}

.kk-mommy-picker__check {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 2px solid var(--ink-faint);
  display: grid;
  place-items: center;
  flex-shrink: 0;
  font-size: 0.8rem;
  transition: all 0.2s;
}

.kk-mommy-picker__item.selected .kk-mommy-picker__check {
  background: var(--apricot);
  border-color: var(--apricot);
  color: white;
}

.kk-mommy-picker__name {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 0.9rem;
}

.kk-mommy-picker__meta {
  font-size: 0.78rem;
  color: var(--ink-light);
}

/* === ANIMATIONS === */
@keyframes staggerIn {
  from { opacity: 0; transform: translateY(16px); }
  to { opacity: 1; transform: translateY(0); }
}

.stagger-in { animation: staggerIn 0.4s ease backwards; }
.stagger-in:nth-child(1) { animation-delay: 0.05s; }
.stagger-in:nth-child(2) { animation-delay: 0.12s; }
.stagger-in:nth-child(3) { animation-delay: 0.19s; }
.stagger-in:nth-child(4) { animation-delay: 0.26s; }
.stagger-in:nth-child(5) { animation-delay: 0.33s; }

/* === CONFETTI (for celebrations) === */
.confetti {
  position: fixed;
  pointer-events: none;
  z-index: 201;
}

.confetti-piece {
  position: absolute;
  width: 10px;
  height: 10px;
  border-radius: 2px;
  animation: confettiFall 1.5s ease forwards;
}

@keyframes confettiFall {
  0% { transform: translateY(0) rotate(0deg); opacity: 1; }
  100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
}

/* === RESPONSIVE === */
@media (max-width: 500px) {
  .kk-hero__inner {
    grid-template-columns: 110px 1fr;
  }
  .kk-hero__img {
    width: 90px;
    height: 90px;
  }
  .kk-hero__line { font-size: 1rem; }
  .kk-quest__tiers { grid-template-columns: 1fr; }
}

@media (min-width: 768px) {
  .kingdom { padding: 28px 32px 140px; }
  .kk-hero__inner { grid-template-columns: 160px 1fr; }
  .kk-hero__img { width: 140px; height: 140px; }
}
